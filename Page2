package com.example.finalproject;

import android.content.Intent;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.Toast;

import androidx.activity.EdgeToEdge;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.graphics.Insets;
import androidx.core.view.ViewCompat;
import androidx.core.view.WindowInsetsCompat;

import com.google.firebase.database.DatabaseReference;
import com.google.firebase.database.FirebaseDatabase;

public class MainActivity2 extends AppCompatActivity {

    EditText e3,e4,e5,e6,e7;
    Button b3;
    String a,b,c,d,e;
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        EdgeToEdge.enable(this);
        setContentView(R.layout.activity_main2);
        ViewCompat.setOnApplyWindowInsetsListener(findViewById(R.id.main), (v, insets) -> {
            Insets systemBars = insets.getInsets(WindowInsetsCompat.Type.systemBars());
            v.setPadding(systemBars.left, systemBars.top, systemBars.right, systemBars.bottom);
            return insets;
        });
        e3=findViewById(R.id.editTextText);
        e4=findViewById(R.id.editTextPhone);
        e5=findViewById(R.id.editTextTextEmailAddress);
        e6=findViewById(R.id.editTextTextPassword);
        e7=findViewById(R.id.editTextTextPassword2);
        b3=findViewById(R.id.button);



        b3.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                e = e4.getText().toString();
                a = e3.getText().toString();
                b = e5.getText().toString();
                c = e6.getText().toString();
                d = e7.getText().toString();

                if(a.isEmpty()||b.isEmpty()||c.isEmpty()||d.isEmpty()||e.isEmpty()){
                    Toast.makeText(MainActivity2.this, "Please fill all fields", Toast.LENGTH_SHORT).show();
                    return;

                }
                if (e.length() < 10) {
                    Toast.makeText(MainActivity2.this, "Enter a valid phone number", Toast.LENGTH_SHORT).show();
                    return;
                }
                if (!android.util.Patterns.EMAIL_ADDRESS.matcher(b).matches()) {
                    Toast.makeText(MainActivity2.this, "Invalid email address", Toast.LENGTH_SHORT).show();
                    return;
                }
                if (c.length() < 8) {
                    Toast.makeText(MainActivity2.this, "Password must be at least 8 characters", Toast.LENGTH_SHORT).show();
                    return;
                }

                if (!c.equals(d)){
                    Toast.makeText(MainActivity2.this, "Password not matched", Toast.LENGTH_SHORT).show();
                    return;
                }

                FirebaseDatabase database = FirebaseDatabase.getInstance();
                DatabaseReference rootRef = database.getReference("Users");
                DatabaseReference userRef = rootRef.child(e);

                userRef.child("Name").setValue(a);
                userRef.child("Phone").setValue(e);
                userRef.child("Email").setValue(b);
                userRef.child("Password").setValue(c);
                userRef.child("ConfirmPassword").setValue(d);


                Toast.makeText(MainActivity2.this, "Account Created Successfully!", Toast.LENGTH_SHORT).show();

                Intent in =new Intent(MainActivity2.this,MainActivity.class);
                startActivity(in);
            }
        });
    }
}
